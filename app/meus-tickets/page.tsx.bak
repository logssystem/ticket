'use client'

import { useState, useEffect } from 'react'
import { AppLayout } from '@/components/layout/app-layout'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import { Plus, Search, Inbox, Loader2, Clock, CheckCircle, AlertCircle } from 'lucide-react'
import { collection, getDocs, query, where } from 'firebase/firestore'
import { db } from '@/lib/firebase'
import { useAuth } from '@/lib/auth-context'
import { cn } from '@/lib/utils'
import { formatDistanceToNow } from 'date-fns'
import { ptBR } from 'date-fns/locale'

type StatusTicket = 'novo' | 'em_andamento' | 'pendente' | 'resolvido' | 'fechado' | 'cancelado'

const statusLabels: Record<StatusTicket, string> = {
  novo: 'Novo',
  em_andamento: 'Em andamento',
  pendente: 'Pendente',
  resolvido: 'Resolvido',
  fechado: 'Fechado',
  cancelado: 'Cancelado',
}

const statusColors: Record<StatusTicket, string> = {
  novo: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  em_andamento: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  pendente: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  resolvido: 'bg-green-500/10 text-green-400 border-green-500/20',
  fechado: 'bg-gray-500/10 text-gray-400 border-gray-500/20',
  cancelado: 'bg-red-500/10 text-red-400 border-red-500/20',
}

interface Ticket {
  id: string
  numero: number
  assunto: string
  descricao: string
  status: StatusTicket
  caixa: string
  categoria: string
  prioridade: string
  abertoEm: Date
}

export default function MeusTicketsPage() {
  const { profile } = useAuth()
  const [tickets, setTickets] = useState<Ticket[]>([])
  const [loading, setLoading] = useState(true)
  const [search, setSearch] = useState('')
  const [filtroStatus, setFiltroStatus] = useState<StatusTicket | 'todos'>('todos')
  const [modalAberto, setModalAberto] = useState(false)

  useEffect(() => {
    if (profile) carregarTickets()
  }, [profile])

  async function carregarTickets() {
    setLoading(true)
    try {
      const resultado: Ticket[] = []
      const idsVistos = new Set<string>()

      // Busca por uid
      if (profile?.uid) {
        const snapUid = await getDocs(
          query(collection(db, 'tickets'), where('clienteUid', '==', profile.uid))
        )
        snapUid.docs.forEach(d => {
          if (!idsVistos.has(d.id)) {
            idsVistos.add(d.id)
            const data = d.data()
            resultado.push({
              id: d.id,
              numero: data.numero,
              assunto: data.assunto,
              descricao: data.descricao,
              status: data.status,
              caixa: data.caixa,
              categoria: data.categoria,
              prioridade: data.prioridade,
              abertoEm: data.abertoEm?.toDate ? data.abertoEm.toDate() : new Date(),
            })
          }
        })
      }

      // Busca por email como fallback
      if (profile?.email) {
        const snapEmail = await getDocs(
          query(collection(db, 'tickets'), where('clienteEmail', '==', profile.email))
        )
        snapEmail.docs.forEach(d => {
          if (!idsVistos.has(d.id)) {
            idsVistos.add(d.id)
            const data = d.data()
            resultado.push({
              id: d.id,
              numero: data.numero,
              assunto: data.assunto,
              descricao: data.descricao,
              status: data.status,
              caixa: data.caixa,
              categoria: data.categoria,
              prioridade: data.prioridade,
              abertoEm: data.abertoEm?.toDate ? data.abertoEm.toDate() : new Date(),
            })
          }
        })
      }

      resultado.sort((a, b) => b.abertoEm.getTime() - a.abertoEm.getTime())
      setTickets(resultado)
    } catch (e) {
      console.error(e)
      setTickets([])
    } finally {
      setLoading(false)
    }
  }

  const filtrados = tickets.filter(t => {
    const matchSearch = t.assunto?.toLowerCase().includes(search.toLowerCase()) ||
      String(t.numero || '').includes(search)
    const matchStatus = filtroStatus === 'todos' || t.status === filtroStatus
    return matchSearch && matchStatus
  })

  const abertos = tickets.filter(t => !['resolvido', 'fechado', 'cancelado'].includes(t.status)).length
  const resolvidos = tickets.filter(t => ['resolvido', 'fechado'].includes(t.status)).length

  return (
    <AppLayout>
      <div className="flex flex-col h-full">
        {/* Header */}
        <div className="flex items-center justify-between px-6 py-4 border-b border-border">
          <div>
            <h1 className="text-lg font-semibold">Meus Tickets</h1>
            <p className="text-sm text-muted-foreground">
              {abertos} aberto{abertos !== 1 ? 's' : ''} · {resolvidos} resolvido{resolvidos !== 1 ? 's' : ''}
            </p>
          </div>
          <Button size="sm" className="gap-2" onClick={() => setModalAberto(true)}>
            <Plus className="h-4 w-4" />
            Novo ticket
          </Button>
        </div>

        {/* Filtros */}
        <div className="flex items-center gap-3 px-6 py-3 border-b border-border flex-wrap">
          <div className="relative flex-1 min-w-[200px] max-w-sm">
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
            <Input
              placeholder="Buscar por assunto ou número..."
              value={search}
              onChange={e => setSearch(e.target.value)}
              className="pl-9"
            />
          </div>
          <div className="flex items-center gap-1 flex-wrap">
            {(['todos', 'novo', 'em_andamento', 'pendente', 'resolvido', 'fechado'] as const).map(s => (
              <button
                key={s}
                onClick={() => setFiltroStatus(s)}
                className={cn(
                  'px-3 py-1.5 text-xs rounded-md transition-colors whitespace-nowrap',
                  filtroStatus === s
                    ? 'bg-primary text-primary-foreground'
                    : 'text-muted-foreground hover:bg-muted hover:text-foreground'
                )}
              >
                {s === 'todos' ? 'Todos' : statusLabels[s]}
              </button>
            ))}
          </div>
        </div>

        {/* Lista */}
        <div className="flex-1 overflow-auto">
          {loading ? (
            <div className="flex items-center justify-center h-40 gap-3 text-muted-foreground">
              <Loader2 className="h-5 w-5 animate-spin" />
              <span className="text-sm">Carregando seus tickets...</span>
            </div>
          ) : filtrados.length === 0 ? (
            <div className="flex flex-col items-center justify-center h-64 text-muted-foreground gap-3">
              <Inbox className="h-12 w-12 opacity-20" />
              <p className="text-sm font-medium">
                {tickets.length === 0 ? 'Nenhum ticket encontrado' : 'Nenhum ticket com este filtro'}
              </p>
              {tickets.length === 0 && (
                <>
                  <p className="text-xs opacity-60">Clique em "Novo ticket" para abrir seu primeiro atendimento</p>
                  <Button size="sm" className="mt-2 gap-2" onClick={() => setModalAberto(true)}>
                    <Plus className="h-4 w-4" />
                    Abrir ticket
                  </Button>
                </>
              )}
            </div>
          ) : (
            <div className="divide-y divide-border">
              {filtrados.map(ticket => (
                <div
                  key={ticket.id}
                  className="flex items-start gap-4 px-6 py-4 hover:bg-muted/30 cursor-pointer transition-colors"
                >
                  {/* Ícone de status */}
                  <div className="flex-shrink-0 mt-1">
                    {['resolvido', 'fechado'].includes(ticket.status) ? (
                      <CheckCircle className="h-5 w-5 text-green-400" />
                    ) : ticket.status === 'pendente' ? (
                      <AlertCircle className="h-5 w-5 text-orange-400" />
                    ) : (
                      <Clock className="h-5 w-5 text-blue-400" />
                    )}
                  </div>

                  <div className="flex-1 min-w-0">
                    <div className="flex items-center gap-2 mb-1 flex-wrap">
                      <span className="text-xs font-mono text-muted-foreground">#{ticket.numero}</span>
                      <span className={cn(
                        'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border',
                        statusColors[ticket.status]
                      )}>
                        {statusLabels[ticket.status]}
                      </span>
                      {ticket.caixa && (
                        <span className="text-xs text-muted-foreground bg-muted px-2 py-0.5 rounded capitalize">
                          {ticket.caixa.replace(/-/g, ' ')}
                        </span>
                      )}
                      {ticket.prioridade && ticket.prioridade !== 'media' && (
                        <span className={cn(
                          'text-xs px-2 py-0.5 rounded border',
                          ticket.prioridade === 'urgente' ? 'bg-red-500/10 text-red-400 border-red-500/20' :
                          ticket.prioridade === 'alta' ? 'bg-orange-500/10 text-orange-400 border-orange-500/20' :
                          'bg-gray-500/10 text-gray-400 border-gray-500/20'
                        )}>
                          {ticket.prioridade}
                        </span>
                      )}
                    </div>
                    <p className="text-sm font-medium truncate">{ticket.assunto}</p>
                    {ticket.descricao && (
                      <p className="text-xs text-muted-foreground truncate mt-0.5">{ticket.descricao}</p>
                    )}
                  </div>

                  <div className="text-xs text-muted-foreground whitespace-nowrap flex-shrink-0">
                    {formatDistanceToNow(ticket.abertoEm, { addSuffix: true, locale: ptBR })}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>

      {/* Modal de novo ticket - importado dinamicamente para evitar problemas */}
      {modalAberto && (
        <NovoTicketInline
          onFechar={() => setModalAberto(false)}
          onCriado={() => { setModalAberto(false); carregarTickets() }}
        />
      )}
    </AppLayout>
  )
}

// Modal inline sem dependência externa
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter } from '@/components/ui/dialog'
import { Label } from '@/components/ui/label'
import { Textarea } from '@/components/ui/textarea'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'
import { addDoc, serverTimestamp, orderBy, limit, getDocs as getDocsLimit } from 'firebase/firestore'
import { criarNotificacao } from '@/lib/notificacoes'
import { toast } from 'sonner'

function NovoTicketInline({ onFechar, onCriado }: { onFechar: () => void; onCriado: () => void }) {
  const { profile } = useAuth()
  const [salvando, setSalvando] = useState(false)
  const [form, setForm] = useState({ assunto: '', descricao: '', categoria: 'problema', prioridade: 'media' })
  const [erros, setErros] = useState<Record<string, string>>({})

  function validar() {
    const e: Record<string, string> = {}
    if (!form.assunto.trim()) e.assunto = 'Obrigatório'
    if (!form.descricao.trim()) e.descricao = 'Obrigatório'
    setErros(e)
    return Object.keys(e).length === 0
  }

  async function salvar() {
    if (!validar() || !profile) return
    setSalvando(true)
    try {
      // Próximo número
      let numero = 100001
      try {
        const snap = await getDocs(query(collection(db, 'tickets'), orderBy('numero', 'desc'), limit(1)))
        if (!snap.empty) numero = (snap.docs[0].data().numero || 100000) + 1
      } catch {}

      await addDoc(collection(db, 'tickets'), {
        numero,
        assunto: form.assunto,
        descricao: form.descricao,
        categoria: form.categoria,
        prioridade: form.prioridade,
        status: 'novo',
        caixa: 'triagem',
        sla: 'nao_definido',
        clienteUid: profile.uid,
        clienteNome: profile.nome,
        clienteEmail: profile.email,
        empresaId: (profile as any).empresaId || null,
        empresaNome: (profile as any).empresaNome || null,
        agenteUid: null,
        agenteNome: null,
        abertoEm: serverTimestamp(),
        vencimentoEm: null,
        resolvidoEm: null,
        atualizadoEm: serverTimestamp(),
      })

      await criarNotificacao({
        tipo: 'novo_ticket',
        titulo: 'Novo ticket aberto',
        mensagem: `#${numero} — ${form.assunto} (${profile.nome})`,
        para: 'todos',
      })

      toast.success(`Ticket #${numero} aberto com sucesso!`)
      onCriado()
    } catch (e) {
      console.error(e)
      toast.error('Erro ao criar ticket.')
    } finally {
      setSalvando(false) }
  }

  return (
    <Dialog open onOpenChange={onFechar}>
      <DialogContent className="max-w-lg">
        <DialogHeader>
          <DialogTitle>Novo ticket</DialogTitle>
        </DialogHeader>
        <div className="space-y-4 py-2">
          <div className="space-y-2">
            <Label>Assunto *</Label>
            <Input placeholder="Descreva brevemente o problema" value={form.assunto} onChange={e => setForm(p => ({ ...p, assunto: e.target.value }))} />
            {erros.assunto && <p className="text-xs text-destructive">{erros.assunto}</p>}
          </div>
          <div className="grid grid-cols-2 gap-3">
            <div className="space-y-2">
              <Label>Categoria</Label>
              <Select value={form.categoria} onValueChange={v => setForm(p => ({ ...p, categoria: v }))}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="problema">Problema</SelectItem>
                  <SelectItem value="duvida">Dúvida</SelectItem>
                  <SelectItem value="solicitacao">Solicitação</SelectItem>
                  <SelectItem value="melhoria">Melhoria</SelectItem>
                  <SelectItem value="financeiro">Financeiro</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div className="space-y-2">
              <Label>Prioridade</Label>
              <Select value={form.prioridade} onValueChange={v => setForm(p => ({ ...p, prioridade: v }))}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="baixa">Baixa</SelectItem>
                  <SelectItem value="media">Média</SelectItem>
                  <SelectItem value="alta">Alta</SelectItem>
                  <SelectItem value="urgente">Urgente</SelectItem>
                </SelectContent>
              </Select>
            </div>
          </div>
          <div className="space-y-2">
            <Label>Descrição *</Label>
            <Textarea
              placeholder="Descreva detalhadamente o que está acontecendo..."
              value={form.descricao}
              onChange={e => setForm(p => ({ ...p, descricao: e.target.value }))}
              rows={5}
              className="resize-none"
            />
            {erros.descricao && <p className="text-xs text-destructive">{erros.descricao}</p>}
          </div>
          <p className="text-xs text-muted-foreground bg-muted/50 px-3 py-2 rounded-md">
            📥 Seu ticket será enviado para a <strong>Triagem</strong> e direcionado para o setor responsável.
          </p>
        </div>
        <DialogFooter>
          <Button variant="outline" onClick={onFechar} disabled={salvando}>Cancelar</Button>
          <Button onClick={salvar} disabled={salvando}>
            {salvando ? <><Loader2 className="mr-2 h-4 w-4 animate-spin" />Enviando...</> : 'Abrir ticket'}
          </Button>
        </DialogFooter>
      </DialogContent>
    </Dialog>
  )
}
